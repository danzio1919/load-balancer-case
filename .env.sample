# Database location (Docker uses /app, local defaults to /backend/data/cluster.db)
DATABASE_URL=sqlite+aiosqlite:////app/backend/data/cluster.db

# Path to system of record files
SERVERS_PATH=/app/servers.json
REQUESTS_PATH=/app/requests.csv

# Outputs paths
RUNS_DIR=/app/runs
RUN_JSONL_PATH=/app/run.jsonl
